# ════════════════════════════════════════════════════════════
# Cosmic Fit — Environment Variables
# ════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.


# ── WP3: Narrative Backfill (Gemini API) ───────────────────
#
# Multi-key rotation (preferred): the backfill script cycles through
# numbered keys in order, switching to the next only when the current
# key's daily quota is exhausted.
GEMINI_API_KEY_1=your_first_gemini_api_key
GEMINI_API_KEY_2=your_second_gemini_api_key
GEMINI_API_KEY_3=your_third_gemini_api_key

# Legacy single-key fallback (used if no numbered keys are set):
# GEMINI_API_KEY=your_gemini_api_key_here

# Optional model override for your shell usage:
# GEMINI_MODEL=gemini-2.0-flash

# Optional per-request client timeout in seconds (default 240, max 600):
# GEMINI_REQUEST_TIMEOUT=300


# ── WP5: Supabase Backend ─────────────────────────────────
#
# Create a project at https://supabase.com, then find these
# values under Project Settings > API > API Keys.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SECRET_KEY=your_supabase_secret_key

# Project ref (used by the Supabase CLI for deployments):
SUPABASE_PROJECT_REF=your_project_ref

# Management API token (used by CLI, not by the app):
# SUPABASE_ACCESS_TOKEN=your_supabase_access_token


# ── WP5: Resend (OTP Email Delivery) ──────────────────────
#
# Sign up at https://resend.com to get an API key.
# For dev/testing, set OTP_EMAIL_PROVIDER=dev to skip real
# email delivery — the OTP code is returned in the API response.
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=login@cosmicfit.app

# "resend" for production email delivery, "dev" for local testing
# (dev mode returns the OTP code in the response, no email sent)
OTP_EMAIL_PROVIDER=dev


# ── WP5: iOS App Config (xcconfig) ────────────────────────
#
# These values are also needed in the Xcode build configuration.
# After filling in above, copy SUPABASE_URL and SUPABASE_PUBLISHABLE_KEY
# into Cosmic Fit/Config/Dev.xcconfig and Prod.xcconfig so they
# are injected into Info.plist at build time.
#
# Dev.xcconfig example:
#   SUPABASE_URL = https://your-project-ref.supabase.co
#   SUPABASE_PUBLISHABLE_KEY = your_supabase_publishable_key
#
# Prod.xcconfig example:
#   SUPABASE_URL = https://your-prod-project-ref.supabase.co
#   SUPABASE_PUBLISHABLE_KEY = your_prod_supabase_publishable_key
