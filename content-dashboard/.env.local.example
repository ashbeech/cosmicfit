# ─────────────────────────────────────────────────────────────
# Content Dashboard — local env
# Copy to `.env.local` and fill in. NEVER commit `.env.local`.
# All vars are server-only — do NOT prefix any with NEXT_PUBLIC_.
# ─────────────────────────────────────────────────────────────

# Supabase — same hosted project the app already uses.
# Supabase dashboard → Project Settings → API.
SUPABASE_URL=https://<your-project-ref>.supabase.co

# Service-role (secret) key. Server-only; bypasses RLS. Never expose to the browser.
# NOTE: this is the SAME secret the repo's Python tooling stores as
#       SUPABASE_SECRET_KEY in the root .env — the dashboard uses the
#       edge-function-canonical name SUPABASE_SERVICE_ROLE_KEY. Same value.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Session signing secret for the jose httpOnly auth cookie.
# Generate a fresh 32-byte value, e.g.:  openssl rand -base64 32
SESSION_SECRET=<32-byte-random-base64>

# ─── Seed-only (used by `npm run seed:users`, not at runtime) ───
# Strong random passwords for the two accounts. Set before seeding, then
# hand the passwords to Maria/Ash out-of-band. Not read by the running app.
SEED_MARIA_PASSWORD=<strong-random-password>
SEED_ASH_PASSWORD=<strong-random-password>
