      ],
      "tests": [
        "the take-off test"
      ]
    },
    "accessory_3": {
      "text": "Look for a small structured bag in smooth stark navy leather. Choose a crisp crossbody shape finished with polished fine hardware in a cool silver tone. This rigid piece grounds the soft movement of any mobile layers you wear over worsted wool. Maintaining pure clean geometry requires absolute structure. Avoid slouchy sacks or distressed canvas entirely. Finally, execute a subtraction check. Strip away the very last accessory you put on. If the technical nylon jacket and silver bag hardware already strike a precise balance, leave that final item on the bed.",
      "sectionIntro": "Secure your final silhouette with rigid accessories and know exactly when to stop adding pieces.",
      "rankedItems": [
        {
          "name": "Small structured bag",
          "role": "accessory category",
          "useCase": "smooth leather crossbody, polished fine hardware"
        }
