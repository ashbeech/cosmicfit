      ]
    },
    "accessory_3": {
      "text": "Anchor your waist with a medium full-grain leather belt. Look for a thick strap and a warm metal casting featuring a flat matt buckle. Contrast this rich baseline by choosing keepsake jewellery forged from aged silver. Search for heavy pieces where oxidised shadows in the metal crevices establish instant hidden depth. Your additions must promise absolute permanence and enduring structure. If a piece feels like a temporary diversion rather than a permanent artifact, take it off immediately.",
      "sectionIntro": "Evaluate your final additions to ensure every element grounds the silhouette.",
      "rankedItems": [
        {
          "name": "Belts",
          "role": "accessory category",
          "useCase": "medium full-grain leather, matt buckle"
        },
        {
          "name": "Keepsake jewellery",
          "role": "accessory category",
          "useCase": "aged silver, oxidised"
        }
