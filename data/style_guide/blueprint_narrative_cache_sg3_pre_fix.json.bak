          "role": "rank 3",
          "useCase": "trousers that drape cleanly and resist creasing through a long day"
        },
        {
          "name": "Technical nylon",
          "role": "rank 4",
          "useCase": "lightweight mobile outerwear that blocks wind and weighs little"
        },
        {
          "name": "Lightweight gabardine",
          "role": "rank 5",
          "useCase": "transitional jackets with rigid structure and no heavy drag"
        },
        {
          "name": "Matt silk",
          "role": "rank 6",
          "useCase": "a frictionless fluid layer added without bulk"
        },
        {
          "name": "Crisp linen",
          "role": "rank 7",
          "useCase": "breathable separation over fluid drapes in warmer weather"
        }
      ],
      "tests": [
        "the flight test"
      ]
    },
    "textures_bad": {
      "text": "Fling the piece upward to observe its behaviour. If it drops like a stone instead of drifting, reject it. Avoid {texture_bad_1}. It traps body heat and binds against the skin. Stay away from {texture_bad_2}, which hangs with a stiff rigidity and resists the breeze. Pick up {texture_bad_3} and squeeze it. If it feels dense and unyielding, leave it on the rack. Your clothing must serve as an airy canvas for one pearl of light. Heavy textiles will smother that subtle glow.",
      "sectionIntro": "Learn the physical tells of the materials that drag you down.",
      "tests": [
        "the flight test"
      ]
