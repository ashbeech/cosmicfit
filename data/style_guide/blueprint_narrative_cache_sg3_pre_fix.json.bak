      ]
    },
    "textures_bad": {
      "text": "Avoid {texture_bad_1} entirely. Pick it up and feel the slick, lifeless surface. It will never provide one polished signal. It just mimics luxury poorly. Test anything suspicious by crushing the cloth in your fist. If you detect a synthetic squeak or a greasy residue, drop the piece immediately. This suffocating trap often hides in {texture_bad_2}. Cool textiles must ventilate naturally. {texture_bad_3} fails this physical check instantly. Leave it on the rail.",
      "sectionIntro": "Train your hands to spot failure before you even check the label.",
      "tests": [
        "the breath test"
      ]
    },
    "textures_sweet_spot": {
      "text": "Combine {sweet_spot_keyword_1} with {sweet_spot_keyword_2} to establish your quiet undercurrent. Test every piece of {texture_good_1} before paying by holding it up to a strong light source. If you see the bulb shining straight through the fibres, put the item back on the rack. You require heavy, dense materials that trap warmth and create a solid boundary. This specific pairing builds a tactile wall between you and the outside world. Keep your cool palette grounded in thick, substantial cloth.",
      "sectionIntro": "Master your signature fabric combinations by testing density and weight.",
      "tests": [
        "the breath test"
      ]
    },
    "palette_narrative": {
      "text": "Keep your colour temperature strictly cool. Build your foundation from {core_colour_1}, {core_colour_2}, and {core_colour_3}. Rely on the actual physical weight of the cloth, trusting the heavy drop of cashmere or the firm edge of full-grain leather to dictate your shape. Substitute harsh whites with {core_colour_4}. Deploy {accent_colour_1} or {accent_colour_2} as your solitary focal point. Treat your relief tone as a soft note used sparingly. Pass over hot saturated red, stark optic white, and harsh neon. Watch for the trap of dissolution. Piling pale, sheer fabrics on top of one another with no foundation causes your silhouette to wash out. Fix this error by restoring a sharp boundary. Add a bias-cut slip that traces the body, wear a fitted base layer, or place a deep anchor right on the skin to rebuild your clean geometry.",
      "sectionIntro": "Rule your palette with strict discipline, leaning on the physical properties of your cloth to guide your choices.",
      "rankedItems": [
        {
          "name": "Inky navy",
          "role": "cool_base"
        },
        {
          "name": "Deep teal",
          "role": "cool_base"
        },
        {
          "name": "Dove grey",
          "role": "cool_base"
        },
        {
