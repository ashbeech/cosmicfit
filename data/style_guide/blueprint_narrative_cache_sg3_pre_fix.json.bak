      ]
    },
    "accessory_2": {
      "text": "Manage your neckwear through strict elimination. Buy scarves only in heavy, matt silk. Look for warm camel tones that drape like liquid weight rather than stiff fabric. Seek sensory comfort in a substantial weave that grounds an outfit without adding glare. Run the removal test before stepping out the door. If a thick wrap competes with a heavy gold chain, take off the accessory that feels like an afterthought. A single strong element builds quiet grandeur. Two focal points create noise. Drop the weak item and trust the remaining weight.",
      "sectionIntro": "Evaluate your secondary layers through strict physical editing.",
      "rankedItems": [
        {
          "name": "Scarves",
          "role": "accessory category",
          "useCase": "silk, matt"
        }
      ],
      "tests": [
