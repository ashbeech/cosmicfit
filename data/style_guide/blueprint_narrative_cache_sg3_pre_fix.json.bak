      ]
    },
    "accessory_3": {
      "text": "Anchor your proportions with a clean leather boot. Choose a smooth calfskin in a deep warm tone, keeping the shape entirely clean to ground the look. The shoe must remain free of excess hardware or complicated stitching. This strict foundation gives you the space to introduce light movement and expansive colour above the ankle. Before leaving the house, scan your reflection for competing focal points. If a heavy hammered brass pendant fights against an elaborate silk collar, remove the piece that disrupts your visual harmony. Keep exactly one theatrical element to draw others closer.",
      "sectionIntro": "Secure your foundation with simple footwear before executing a final visual check.",
      "rankedItems": [
        {
          "name": "Footwear",
          "role": "accessory category",
          "useCase": "clean leather boot, clean"
        }
      ],
      "tests": [
