{
  "schema_version": 2,
  "venus_aquarius__moon_aries__air_dominant": {
    "coreFormula": "clean geometry + sharp edges + one polished signal",
    "closing": "Your style guide is a map of your own instincts, built on clean geometry + sharp edges + one polished signal.",
    "style_core": {
      "text": "Your physical instinct for crispness is your ultimate compass. When you pick up a garment, feel for structural integrity and smooth surfaces. Looks lie. Weight and tension do not. Build your wardrobe around the formula of clean geometry + sharp edges + one polished signal. Picture a rigid tailored blazer layered over a fine-gauge high-neck top, anchored by perfectly creased trousers and finished with a high-shine reflective cuff. The garments must hold their shape independent of your body. If a piece feels limp or requires constant adjustment, drop it immediately.\n\nBuild your wardrobe modularly and deploy it to suit the shifting demands of the day. Every element must adapt to new contexts while maintaining a cool visual temperature and a strict finish. Before you commit to any item, subject it to the seam test. Turn the garment inside out and run your thumb firmly along the internal stitching. You are feeling for flat, unyielding construction. If the threads catch or the joining feels bulky and uneven, the piece will fail you when you need it to perform. Trust your hands over any label.",
      "sectionIntro": "This is the architecture of your wardrobe, the fundamental formula and physical tests you will use to evaluate every garment.",
      "tests": [
        "the seam test"
      ]
    },
    "textures_good": {
      "text": "Your wardrobe requires fabrics that support clean geometry. Look for {texture_good_1} when selecting shirting for clean architectural boundaries and pure separation. Pick {texture_good_2} for close-to-body base layers that deliver sharp edges and easy movement. Trust your hands and apply the recovery test. Crush the fabric in your fist for five seconds and release it. If the wrinkles remain, leave the garment on the rack. You require resilient materials that bounce back to maintain one polished signal. Rely on {texture_good_3} for trousers that drape cleanly and resist creasing through a long day. Finish with {texture_good_4} for lightweight mobile outerwear that blocks wind and weighs little. Begin your selection with the ranked options below.",
      "sectionIntro": "Build your foundation on textiles that hold their shape and deliver crisp boundaries.",
      "rankedItems": [
        {
          "name": "Crisp cotton poplin",
          "role": "rank 1",
          "useCase": "shirting with clean architectural boundaries and pure separation"
        },
        {
          "name": "Fine ribbed merino",
          "role": "rank 2",
          "useCase": "close-to-body base layers with sharp lines and easy movement"
        },
        {
          "name": "Worsted wool",
          "role": "rank 3",
          "useCase": "trousers that drape cleanly and resist creasing through a long day"
        },
        {
          "name": "Technical nylon",
          "role": "rank 4",
          "useCase": "lightweight mobile outerwear that blocks wind and weighs little"
        },
        {
          "name": "Lightweight gabardine",
          "role": "rank 5",
          "useCase": "transitional jackets with rigid structure and no heavy drag"
        },
        {
          "name": "Matt silk",
          "role": "rank 6",
          "useCase": "a frictionless fluid layer added without bulk"
        },
        {
          "name": "Crisp linen",
          "role": "rank 7",
          "useCase": "breathable separation over fluid drapes in warmer weather"
        }
      ],
      "tests": [
        "the recovery test"
      ]
    },
    "textures_bad": {
      "text": "If {texture_bad_1} feels stifling rather than cool against the skin, drop it. Squeeze the sleeve tightly, then let go. If the fibres hold a crease instead of springing back flat, the material fails your baseline. Leave it on the rail. Your aesthetic relies on sharp edges. Any fabric that crumples will undermine that line. Avoid {texture_bad_2} entirely. Its physical tell is a brittle stiffness that fights the body instead of adapting. Step away from {texture_bad_3} if the weave feels spongy. Pull the material taut across your knuckles. If it yields without instantly snapping back to its original tension, it will warp by midday. Surfaces deceive. Structural resistance does not.",
      "sectionIntro": "Learn to reject materials that fail your physical baseline.",
      "tests": [
        "the recovery test"
      ]
    },
    "textures_sweet_spot": {
      "text": "Merge {sweet_spot_keyword_1} and {sweet_spot_keyword_2} to construct your base. You are looking for materials that hold sharp edges without stiffness. Gather a handful of {texture_good_1} into your palm. Release your grip. If the item stays crumpled, discard it on the spot. It must snap back to a smooth, flat plane immediately. You need materials that recover on their own. The surface must feel cool and crisp against your skin. Avoid anything that clings or sags at the seams. Keep the lines exact.",
      "sectionIntro": "Build your foundation by testing exactly how materials behave under pressure.",
      "tests": [
        "the recovery test"
      ]
    },
    "palette_narrative": {
      "text": "Keep your palette strictly cool. Build your foundation from {core_colour_1} and {core_colour_2}. Rely on {core_colour_3} as your bright neutral to create stark contrast next to the grounding weight of {core_colour_4}. Deploy {accent_colour_1} or {accent_colour_2} as a deliberate addition. Introduce a soft relief tone sparingly when stark contrast feels too rigid. Leave mustard, rust, and warm olive green on the rail. Watch for the pale-wash trap, where wearing every item at an identical light value looks unresolved rather than minimal. Rescue this error with a {core_colour_4} anchor or a {accent_colour_1} focal point, and let a shift in weave restore the visual depth. Ground these colour choices with sharp edges to maintain crisp definition. Trust your own vision to guide these adjustments.",
      "sectionIntro": "Control your impact by anchoring every choice within a structured, disciplined colour system.",
      "rankedItems": [
        {
          "name": "Stark navy",
          "role": "cool_base"
        },
        {
          "name": "Icy grey",
          "role": "cool_base"
        },
        {
          "name": "Optical white",
          "role": "white_substitute"
        },
        {
          "name": "Deep slate",
          "role": "structural_dark"
        },
        {
