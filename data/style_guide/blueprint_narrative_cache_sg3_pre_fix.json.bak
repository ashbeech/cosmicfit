      ]
    },
    "textures_sweet_spot": {
      "text": "Your sweet spot pairs {sweet_spot_keyword_1} with {sweet_spot_keyword_2}. Squeeze the sleeve of any item. Press it hard with your fingers. It must spring back immediately. If it retains a crushed wrinkle, discard it. A polished {texture_good_1} guarantees cool composure. Maintain a warm tone across your layers to ground the silhouette. Mix dual register metals to introduce controlled contrast. Add one hot accent to complete the logic.",
      "sectionIntro": "Nail your fabric pairings to ensure your items perform exactly as intended.",
      "tests": [
        "the edge test"
      ]
    },
    "palette_narrative": {
      "text": "Your palette demands a warm thermal baseline. Build your structural pieces using {core_colour_1} and {core_colour_2} as primary dark neutrals. Substitute harsh whites with {core_colour_3} and bridge darker items with {core_colour_4}. Deliver your one hot accent by placing {accent_colour_1} or {accent_colour_2} against crisp worsted wool or technical nylon. Treat your relief tone strictly as a soft note used sparingly near the face. Pass over icy pastel, neon brights, and cold blue-grey. These shades dilute the outfit's visual density. Watch for the total ice trap. Unbroken grey on grey reads as visual absence rather than cool composure. Fix this by introducing a polished signal. Add a mirror-finish cuff, a patent boot, or one line of electric colour to restore your balance.",
      "sectionIntro": "Establish a warm thermal baseline, filtering out any shade that dilutes your clarity.",
