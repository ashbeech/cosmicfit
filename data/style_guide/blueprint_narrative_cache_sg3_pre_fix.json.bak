        },
        {
          "name": "Brushed cotton flannel",
          "role": "rank 7",
          "useCase": "shirts and loungewear that feel like a remembered embrace"
        }
      ],
      "tests": [
        "the breath test"
      ]
    },
    "textures_bad": {
      "text": "Drop {texture_bad_1} back on the rail the moment it squeaks between your fingers. It lacks the cool composure your style demands. Test the porosity of anything resembling {texture_bad_2}. Press the item to your lips and blow through the warp. If the draft bounces back and heats your face, the weave is dead plastic. Leave it behind. Reject {texture_bad_3} when it feels slick and hollow under your thumb. Your skin requires a warm, matt touch. A harsh synthetic traps perspiration and suffocates the wearer.",
      "sectionIntro": "Learn to reject a bad textile the second it touches your skin.",
      "tests": [
        "the breath test"
      ]
    },
    "textures_sweet_spot": {
      "text": "Seek the exact junction of {sweet_spot_keyword_1} and {sweet_spot_keyword_2}. Pick up a piece of {texture_good_1} and inspect the gauge. Hold the textile to a light source. You require open threads to maintain cool composure. Depend on your hands to judge the density. Squeeze the hem between your thumb and forefinger. A thick drape ensures a clean fall. Combine a matt surface with a living finish. Vision plays tricks, but the physical substance of cloth in your grip reveals everything.",
      "sectionIntro": "This is how you calibrate the physical balance of your materials.",
      "tests": [
        "the breath test"
      ]
