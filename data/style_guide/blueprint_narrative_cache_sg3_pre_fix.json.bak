      ]
    },
    "textures_sweet_spot": {
      "text": "Your signature pairing lives precisely where {sweet_spot_keyword_1} meets {sweet_spot_keyword_2}. This friction provides the exact structure and softness you require. Seek out {texture_good_1} with a strictly matt finish. Apply a practical lighting check. Observe the material in a shadowed room illuminated by a single warm flame. If the surface glows gently from within, keep it. If it throws a harsh reflection, drop it immediately. Your style demands self-contained textures that hold their secrets close. Trust your grip. Heavy, dense cloth always tells the truth.",
      "sectionIntro": "Master your pairings by feeling the physical friction between contrasting materials.",
      "tests": [
