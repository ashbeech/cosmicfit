        {
          "name": "Patent leather",
          "role": "rank 3",
          "useCase": "statement footwear and accessories that reflect maximum light"
        },
        {
          "name": "Heavy silk satin",
          "role": "rank 4",
          "useCase": "slip dresses and linings that gleam under low light"
        },
        {
          "name": "Techno gabardine",
          "role": "rank 5",
          "useCase": "wrinkle-resistant trousers and jackets that keep a rigid shape"
        },
